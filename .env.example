# Optional local overrides. Normal users can run BlogCraft without this file.

# Optional custom Google OAuth Client ID.
# Leave unset to use BlogCraft's bundled client ID.
# REACT_APP_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Optional CKEditor/TinyMCE-style editor API key if you use one.
REACT_APP_TINYMCE_API_KEY=

# Optional local production server port used by npm run serve or release binaries.
# PORT=3000

# Optional scheduler settings used by npm run scheduler.
# BLOGGER_TOKEN=
# SCHEDULED_POSTS_FILE=scheduled-posts.json
